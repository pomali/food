---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getProductBySlug, getProductSlugs, type ProductDetail } from "../../lib/db";

interface Props {
  product: ProductDetail;
}

export async function getStaticPaths() {
  const slugs = await getProductSlugs();
  return Promise.all(
    slugs.map(async (slug: string) => ({
      params: { slug },
      props: { product: await getProductBySlug(slug) },
    })),
  );
}

const { product } = Astro.props as Props;
---

<BaseLayout title={`${product.name} | Product`} description={product.description}>
  <article class="card" style="padding:1rem;">
    <h2 style="margin-top:0;">{product.name}</h2>
    <p style="margin-top:0;">{product.description}</p>
    <p class="muted">Category: {product.category}</p>

    <section>
      <h3>Allergens</h3>
      <p>{product.allergens.length ? product.allergens.join(", ") : "No declared allergens."}</p>
    </section>

    {product.nutritionPer100g ? (
      <section>
        <h3>Nutrition per 100 g</h3>
        <ul style="padding-left:1.2rem;">
          {product.nutritionPer100g.caloriesKcal ? <li>{product.nutritionPer100g.caloriesKcal} kcal</li> : null}
          {product.nutritionPer100g.proteinG ? <li>{product.nutritionPer100g.proteinG} g protein</li> : null}
          {product.nutritionPer100g.carbsG ? <li>{product.nutritionPer100g.carbsG} g carbs</li> : null}
          {product.nutritionPer100g.fatG ? <li>{product.nutritionPer100g.fatG} g fat</li> : null}
        </ul>
      </section>
    ) : null}

    <section>
      <h3>Tags</h3>
      <div style="display:flex;flex-wrap:wrap;gap:0.35rem;">
        {product.tags.map((tag: string) => <span class="pill">{tag}</span>)}
      </div>
    </section>

    {product.relatedRecipes.length ? (
      <section>
        <h3>Used in Recipes</h3>
        <ul style="padding-left:1.2rem;">
          {product.relatedRecipes.map((recipe) => (
            <li><a href={`/recipes/${recipe.slug}/`}>{recipe.name}</a></li>
          ))}
        </ul>
      </section>
    ) : null}

    <section>
      <h3>Notes</h3>
      <div set:html={product.notesHtml} />
    </section>
  </article>
</BaseLayout>
